{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"customTemplates": [
		{
			"name": "blank",
			"postTypes": [
				"page",
				"post"
			],
			"title": "Blank"
		},
		{
			"name": "blog-alternative",
			"postTypes": [
				"page"
			],
			"title": "Blog (Alternative)"
		},
		{
			"name": "404",
			"postTypes": [
				"page"
			],
			"title": "404"
		}
	],
	"settings": {
		"appearanceTools": true,
		"color": {
			"palette": [
				{
					"color": "#ffffff",
					"name": "Base",
					"slug": "base"
				},
				{
					"color": "#000000",
					"name": "Contrast",
					"slug": "contrast"
				},
				{
					"color": "#1d76da",
					"name": "Primary",
					"slug": "primary"
				},
				{
					"color": "#3c8ce6",
					"name": "Secondary",
					"slug": "secondary"
				},
				{
					"color": "#F6F6F6",
					"name": "Tertiary",
					"slug": "tertiary"
				}
			]
		},
		"spacing": {
			"blockGap": true,
			"margin": true,
			"padding": true,
			"units": [
				"%",
				"px",
				"em",
				"rem",
				"vh",
				"vw"
			]
		},
		"typography": {
			"fontFamilies": [
				{
					"fontFamily": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen-Sans, Ubuntu, Cantarell, 'Helvetica Neue', sans-serif",
					"name": "System Font",
					"slug": "system"
				}
			],
			"fontSizes": [
				{
					"size": "0.8125rem",
					"slug": "small",
					"name": "Small"
				},
				{
					"size": "1rem",
					"slug": "medium",
					"name": "Medium"
				},
				{
					"size": "1.25rem",
					"slug": "large",
					"name": "Large"
				},
				{
					"size": "1.75rem",
					"slug": "x-large",
					"name": "Extra Large"
				},
				{
					"size": "2.5rem",
					"slug": "xx-large",
					"name": "Huge"
				}
			]
		},
		"layout": {
			"contentSize": "840px",
			"wideSize": "1200px"
		}
	},
	"styles": {
		"elements": {
			"link": {
				"typography": {
					"textDecoration": "none"
				}
			},
			"button": {
				"color": {
					"text": "#fff",
					"background": "var(--wp--preset--color--primary)"
				},
				":hover": {
					"color": {
						"background": "var(--wp--preset--color--secondary)"
					}
				}
			},
			"heading": {
				"color": {
					"text": "#20262e"
				}
			}
		},
		"blocks": {
			"core/button": {
				"border": {
					"radius": "8px"
				},
				"typography": {
					"fontWeight": "600"
				}
			},
			"core/quote": {
				"border": {
					"left": {
						"color": "var(--wp--preset--color--primary)",
						"width": "4px",
						"style": "solid"
					}
				},
				"spacing": {
					"padding": {
						"left": "1.25em"
					}
				}
			},
			"core/pullquote": {
				"border": {
					"top": {
						"color": "var(--wp--preset--color--primary)",
						"width": "4px",
						"style": "solid"
					},
					"bottom": {
						"color": "var(--wp--preset--color--primary)",
						"width": "4px",
						"style": "solid"
					}
				}
			},
			"core/separator": {
				"color": {
					"background": "#e3e3e3"
				},
				"border": {
					"color": "#e3e3e3"
				}
			},
			"core/table": {
				"border": {
					"color": "#e3e3e3"
				}
			},
			"core/code": {
				"color": {
					"background": "#f6f6f6",
					"text": "#20262e"
				},
				"border": {
					"radius": "8px"
				},
				"spacing": {
					"padding": {
						"top": "1.25em",
						"right": "1.5em",
						"bottom": "1.25em",
						"left": "1.5em"
					}
				},
				"typography": {
					"fontSize": "0.875rem"
				}
			},
			"core/preformatted": {
				"color": {
					"background": "#f6f6f6",
					"text": "#20262e"
				},
				"border": {
					"radius": "8px"
				},
				"spacing": {
					"padding": {
						"top": "1.25em",
						"right": "1.5em",
						"bottom": "1.25em",
						"left": "1.5em"
					}
				}
			},
			"core/image": {
				"border": {
					"radius": "8px"
				}
			},
			"core/group": {
				"border": {
					"radius": "8px"
				}
			}
		}
	},
	"templateParts": [
		{
			"area": "header",
			"name": "header",
			"title": "Header"
		},
		{
			"area": "footer",
			"name": "footer",
			"title": "Footer"
		},
		{
			"area": "general",
			"name": "comments",
			"title": "Comments"
		},
		{
			"area": "general",
			"name": "post-meta",
			"title": "Post Meta"
		}
	]
}